APP_NAME=CimTalent AI
APP_ENV=development
DEBUG=false
API_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cimtalent
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=["http://localhost:5173"]
DEBUG_ARTIFACT_RETENTION_DAYS=7
ENABLE_LINKEDIN_PEOPLE_SEARCH=false
ENABLE_GOOGLE_API_SEARCH=false
ENABLE_AI_PROVIDER=false
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=30000
BROWSER_NAVIGATION_TIMEOUT_MS=45000
BROWSER_VIEWPORT_WIDTH=1440
BROWSER_VIEWPORT_HEIGHT=900
BROWSER_SLOW_MO_MS=0
BROWSER_USER_AGENT=
LINKEDIN_SESSION_FILE=.sessions/linkedin.json
BROWSER_ARTIFACT_DIR=.artifacts/browser
BROWSER_SAVE_SCREENSHOT_ON_ERROR=true
BROWSER_SAVE_HTML_ON_ERROR=false
BROWSER_ARTIFACT_RETENTION_DAYS=3
LINKEDIN_BASE_URL=https://www.linkedin.com
LINKEDIN_LOGIN_TIMEOUT_SECONDS=300
ENRICHMENT_MAX_REQUEST_BYTES=2000000
